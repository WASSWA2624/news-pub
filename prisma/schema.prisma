generator client {
  provider      = "prisma-client-js"
  compilerBuild = "small"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum EditorialStage {
  INGESTED
  REVIEWED
  EDITED
  APPROVED
}

enum WorkflowStage {
  INGESTED
  OPTIMIZED
  HELD
  REVIEW_REQUIRED
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum OptimizationStatus {
  NOT_REQUESTED
  PENDING
  COMPLETED
  FALLBACK
  SKIPPED
  FAILED
}

enum PolicyReviewStatus {
  PASS
  HOLD
  BLOCK
}

enum DestinationPlatform {
  WEBSITE
  FACEBOOK
  INSTAGRAM
}

enum DestinationKind {
  WEBSITE
  FACEBOOK_PROFILE
  FACEBOOK_PAGE
  INSTAGRAM_PERSONAL
  INSTAGRAM_BUSINESS
}

enum ConnectionStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum StreamMode {
  AUTO_PUBLISH
  REVIEW_REQUIRED
}

enum StreamStatus {
  ACTIVE
  PAUSED
}

enum ArticleMatchStatus {
  ELIGIBLE
  HELD_FOR_REVIEW
  QUEUED
  PUBLISHED
  FAILED
  DUPLICATE
  SKIPPED
}

enum PublishAttemptStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum FetchRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ViewEventType {
  WEBSITE_VIEW
  PAGE_VIEW
  POST_VIEW
  SEARCH_VIEW
}

model Locale {
  code                 String                @id @db.VarChar(16)
  name                 String                @db.VarChar(64)
  is_active            Boolean               @default(true)
  is_default           Boolean               @default(false)
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt
  postTranslations     PostTranslation[]
  destinationTemplates DestinationTemplate[]
  optimizationCaches   OptimizationCache[]
  publishingStreams    PublishingStream[]
  viewEvents           ViewEvent[]

  @@map("locale")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique @db.VarChar(191)
  name          String         @db.VarChar(191)
  password_hash String         @db.VarChar(255)
  role          UserRole
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  adminSessions AdminSession[]
  authoredPosts Post[]         @relation("PostAuthor")
  auditEvents   AuditEvent[]
  fetchRuns     FetchRun[]     @relation("FetchRunRequester")

  @@map("user")
}

model AdminSession {
  id             String    @id @default(cuid())
  user_id        String
  token_hash     String    @unique @db.VarChar(64)
  expires_at     DateTime
  invalidated_at DateTime?
  created_at     DateTime  @default(now())
  last_used_at   DateTime  @default(now())
  user_agent     String?   @db.VarChar(512)
  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id, expires_at])
  @@map("admin_session")
}

model NewsProviderConfig {
  id                    String                    @id @default(cuid())
  provider_key          String                    @unique @db.VarChar(64)
  label                 String                    @db.VarChar(191)
  description           String?                   @db.LongText
  base_url              String?                   @db.VarChar(2048)
  is_default            Boolean                   @default(false)
  is_enabled            Boolean                   @default(true)
  is_selectable         Boolean                   @default(true)
  request_defaults_json Json?
  created_at            DateTime                  @default(now())
  updated_at            DateTime                  @updatedAt
  streams               PublishingStream[]        @relation("StreamProvider")
  checkpoints           ProviderFetchCheckpoint[]
  fetchedArticles       FetchedArticle[]
  fetchRuns             FetchRun[]

  @@index([is_enabled, is_default])
  @@map("news_provider_config")
}

model Destination {
  id                         String              @id @default(cuid())
  name                       String              @db.VarChar(191)
  slug                       String              @unique @db.VarChar(191)
  platform                   DestinationPlatform
  kind                       DestinationKind
  account_handle             String?             @db.VarChar(191)
  external_account_id        String?             @db.VarChar(191)
  connection_status          ConnectionStatus    @default(DISCONNECTED)
  connection_error           String?             @db.LongText
  encrypted_token_ciphertext String?             @db.LongText
  encrypted_token_iv         String?             @db.VarChar(64)
  encrypted_token_tag        String?             @db.VarChar(64)
  token_hint                 String?             @db.VarChar(64)
  settings_json              Json?
  last_checked_at            DateTime?
  last_connected_at          DateTime?
  created_at                 DateTime            @default(now())
  updated_at                 DateTime            @updatedAt
  streams                    PublishingStream[]
  articleMatches             ArticleMatch[]
  publishAttempts            PublishAttempt[]

  @@index([platform, connection_status])
  @@map("destination")
}

model Category {
  id                   String                @id @default(cuid())
  name                 String                @unique @db.VarChar(191)
  slug                 String                @unique @db.VarChar(191)
  description          String?               @db.LongText
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt
  posts                PostCategory[]
  streamAssignments    StreamCategory[]
  destinationTemplates DestinationTemplate[]

  @@map("category")
}

model MediaAsset {
  id               String           @id @default(cuid())
  file_name        String?          @db.VarChar(255)
  file_size_bytes  Int?
  storage_driver   String           @db.VarChar(32)
  storage_key      String?          @db.VarChar(255)
  public_url       String?          @db.VarChar(2048)
  local_path       String?          @db.VarChar(512)
  source_url       String?          @db.VarChar(2048)
  source_domain    String?          @db.VarChar(191)
  alt              String?          @db.LongText
  caption          String?          @db.LongText
  mime_type        String?          @db.VarChar(191)
  width            Int?
  height           Int?
  attribution_text String?          @db.LongText
  license_type     String?          @db.VarChar(128)
  license_notes    String?          @db.LongText
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  variants         MediaVariant[]
  featuredInPosts  Post[]           @relation("PostFeaturedImage")
  fetchedArticles  FetchedArticle[]
  seoOgRecords     SEORecord[]      @relation("SeoOgImage")

  @@index([source_domain])
  @@map("media_asset")
}

model MediaVariant {
  id              String     @id @default(cuid())
  media_asset_id  String
  variant_key     String     @db.VarChar(64)
  format          String     @db.VarChar(32)
  mime_type       String?    @db.VarChar(191)
  width           Int
  height          Int
  file_size_bytes Int?
  storage_key     String?    @db.VarChar(255)
  public_url      String?    @db.VarChar(2048)
  local_path      String?    @db.VarChar(512)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  mediaAsset      MediaAsset @relation(fields: [media_asset_id], references: [id], onDelete: Cascade)

  @@index([media_asset_id])
  @@index([media_asset_id, variant_key])
  @@map("media_variant")
}

model FetchedArticle {
  id                       String             @id @default(cuid())
  provider_config_id       String
  featured_media_id        String?
  provider_article_id      String?            @db.VarChar(191)
  dedupe_fingerprint       String             @unique @db.VarChar(191)
  source_url_hash          String?            @db.VarChar(64)
  normalized_title_hash    String             @db.VarChar(64)
  source_name              String             @db.VarChar(191)
  source_url               String             @db.VarChar(2048)
  title                    String             @db.VarChar(255)
  summary                  String?            @db.LongText
  body                     String?            @db.LongText
  author                   String?            @db.VarChar(191)
  published_at             DateTime
  image_url                String?            @db.VarChar(2048)
  language                 String?            @db.VarChar(32)
  provider_categories_json Json?
  provider_countries_json  Json?
  provider_regions_json    Json?
  tags_json                Json?
  raw_payload_json         Json?
  fetch_timestamp          DateTime           @default(now())
  created_at               DateTime           @default(now())
  updated_at               DateTime           @updatedAt
  providerConfig           NewsProviderConfig @relation(fields: [provider_config_id], references: [id], onDelete: Restrict)
  featuredMedia            MediaAsset?        @relation(fields: [featured_media_id], references: [id], onDelete: SetNull)
  articleMatches           ArticleMatch[]
  posts                    Post[]             @relation("PostSourceArticle")

  @@unique([provider_config_id, provider_article_id])
  @@index([provider_config_id, published_at])
  @@index([source_url_hash, published_at])
  @@index([normalized_title_hash, published_at])
  @@map("fetched_article")
}

model Post {
  id                     String            @id @default(cuid())
  source_article_id      String?           @unique
  slug                   String            @unique @db.VarChar(191)
  status                 PostStatus        @default(DRAFT)
  editorial_stage        EditorialStage    @default(INGESTED)
  canonical_content_hash String?           @db.VarChar(64)
  source_name            String            @db.VarChar(191)
  source_url             String            @db.VarChar(2048)
  provider_key           String            @db.VarChar(64)
  excerpt                String            @db.LongText
  featured_image_id      String?
  author_id              String?
  scheduled_publish_at   DateTime?
  published_at           DateTime?
  created_at             DateTime          @default(now())
  updated_at             DateTime          @updatedAt
  sourceArticle          FetchedArticle?   @relation("PostSourceArticle", fields: [source_article_id], references: [id], onDelete: SetNull)
  featuredImage          MediaAsset?       @relation("PostFeaturedImage", fields: [featured_image_id], references: [id], onDelete: SetNull)
  author                 User?             @relation("PostAuthor", fields: [author_id], references: [id], onDelete: SetNull)
  translations           PostTranslation[]
  categories             PostCategory[]
  articleMatches         ArticleMatch[]
  publishAttempts        PublishAttempt[]
  viewEvents             ViewEvent[]

  @@index([status, published_at])
  @@index([status, published_at, updated_at])
  @@index([status, scheduled_publish_at])
  @@map("post")
}

model PostTranslation {
  id                      String     @id @default(cuid())
  post_id                 String
  locale                  String     @db.VarChar(16)
  title                   String     @db.VarChar(255)
  summary                 String     @db.LongText
  content_md              String     @db.LongText
  content_html            String     @db.LongText
  structured_content_json Json
  source_attribution      String     @db.LongText
  created_at              DateTime   @default(now())
  updated_at              DateTime   @updatedAt
  post                    Post       @relation(fields: [post_id], references: [id], onDelete: Cascade)
  localeRecord            Locale     @relation(fields: [locale], references: [code], onDelete: Restrict)
  seoRecord               SEORecord?

  @@unique([post_id, locale])
  @@index([locale, post_id])
  @@fulltext([content_md], map: "post_translation_content_md_fts_idx")
  @@map("post_translation")
}

model ProviderFetchCheckpoint {
  id                       String             @id @default(cuid())
  stream_id                String
  provider_config_id       String
  last_successful_fetch_at DateTime?
  cursor_json              Json?
  created_at               DateTime           @default(now())
  updated_at               DateTime           @updatedAt
  stream                   PublishingStream   @relation(fields: [stream_id], references: [id], onDelete: Cascade)
  providerConfig           NewsProviderConfig @relation(fields: [provider_config_id], references: [id], onDelete: Cascade)

  @@unique([stream_id, provider_config_id])
  @@map("provider_fetch_checkpoint")
}

model PublishingStream {
  id                        String                    @id @default(cuid())
  name                      String                    @db.VarChar(191)
  slug                      String                    @unique @db.VarChar(191)
  description               String?                   @db.LongText
  destination_id            String
  active_provider_id        String
  default_template_id       String?
  locale                    String                    @db.VarChar(16)
  timezone                  String                    @db.VarChar(64)
  schedule_interval_minutes Int                       @default(60)
  mode                      StreamMode
  status                    StreamStatus              @default(ACTIVE)
  max_posts_per_run         Int                       @default(5)
  duplicate_window_hours    Int                       @default(48)
  retry_limit               Int                       @default(3)
  retry_backoff_minutes     Int                       @default(15)
  language_allowlist_json   Json?
  country_allowlist_json    Json?
  region_allowlist_json     Json?
  include_keywords_json     Json?
  exclude_keywords_json     Json?
  settings_json             Json?
  consecutive_failure_count Int                       @default(0)
  last_run_started_at       DateTime?
  last_run_completed_at     DateTime?
  last_failure_at           DateTime?
  next_run_at               DateTime?
  created_at                DateTime                  @default(now())
  updated_at                DateTime                  @updatedAt
  destination               Destination               @relation(fields: [destination_id], references: [id], onDelete: Cascade)
  activeProvider            NewsProviderConfig        @relation("StreamProvider", fields: [active_provider_id], references: [id], onDelete: Restrict)
  defaultTemplate           DestinationTemplate?      @relation("StreamDefaultTemplate", fields: [default_template_id], references: [id], onDelete: SetNull)
  localeRecord              Locale                    @relation(fields: [locale], references: [code], onDelete: Restrict)
  categories                StreamCategory[]
  checkpoints               ProviderFetchCheckpoint[]
  articleMatches            ArticleMatch[]
  publishAttempts           PublishAttempt[]
  fetchRuns                 FetchRun[]

  @@index([status, destination_id])
  @@index([destination_id, mode, status])
  @@index([active_provider_id, status])
  @@index([status, next_run_at])
  @@map("publishing_stream")
}

model ArticleMatch {
  id                     String             @id @default(cuid())
  fetched_article_id     String
  stream_id              String
  destination_id         String
  canonical_post_id      String?
  optimization_cache_id  String?
  status                 ArticleMatchStatus
  workflow_stage         WorkflowStage      @default(INGESTED)
  optimization_status    OptimizationStatus @default(NOT_REQUESTED)
  policy_status          PolicyReviewStatus @default(PASS)
  optimization_hash      String?            @db.VarChar(64)
  optimized_payload_json Json?
  policy_reasons_json    Json?
  readiness_checks_json  Json?
  ban_risk_score         Int?
  last_optimized_at      DateTime?
  last_policy_checked_at DateTime?
  review_notes           String?            @db.LongText
  filter_reasons_json    Json?
  hold_reasons_json      Json?
  duplicate_of_match_id  String?
  duplicate_fingerprint  String?            @db.VarChar(191)
  queued_at              DateTime?
  published_at           DateTime?
  failed_at              DateTime?
  override_notes         String?            @db.LongText
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt
  fetchedArticle         FetchedArticle     @relation(fields: [fetched_article_id], references: [id], onDelete: Cascade)
  stream                 PublishingStream   @relation(fields: [stream_id], references: [id], onDelete: Cascade)
  destination            Destination        @relation(fields: [destination_id], references: [id], onDelete: Cascade)
  canonicalPost          Post?              @relation(fields: [canonical_post_id], references: [id], onDelete: SetNull)
  optimizationCache      OptimizationCache? @relation(fields: [optimization_cache_id], references: [id], onDelete: SetNull)
  duplicateOf            ArticleMatch?      @relation("DuplicateArticleMatch", fields: [duplicate_of_match_id], references: [id], onDelete: SetNull)
  duplicates             ArticleMatch[]     @relation("DuplicateArticleMatch")
  publishAttempts        PublishAttempt[]

  @@unique([fetched_article_id, stream_id])
  @@index([stream_id, status])
  @@index([stream_id, workflow_stage])
  @@index([destination_id, status])
  @@index([destination_id, policy_status])
  @@index([canonical_post_id])
  @@map("article_match")
}

model OptimizationCache {
  id                String              @id @default(cuid())
  cache_key         String              @unique @db.VarChar(191)
  content_hash      String              @db.VarChar(64)
  settings_hash     String              @db.VarChar(64)
  optimization_hash String              @db.VarChar(64)
  locale            String?             @db.VarChar(16)
  platform          DestinationPlatform
  destination_kind  DestinationKind
  status            OptimizationStatus  @default(PENDING)
  policy_status     PolicyReviewStatus  @default(PASS)
  provider          String?             @db.VarChar(64)
  model             String?             @db.VarChar(128)
  used_fallback     Boolean             @default(false)
  ban_risk_score    Int?
  result_json       Json?
  warnings_json     Json?
  error_message     String?             @db.LongText
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt
  localeRecord      Locale?             @relation(fields: [locale], references: [code], onDelete: SetNull)
  articleMatches    ArticleMatch[]

  @@index([platform, destination_kind, locale])
  @@index([status, updated_at])
  @@map("optimization_cache")
}

model DestinationTemplate {
  id                String              @id @default(cuid())
  name              String              @db.VarChar(191)
  platform          DestinationPlatform
  locale            String?             @db.VarChar(16)
  category_id       String?
  title_template    String?             @db.LongText
  summary_template  String?             @db.LongText
  body_template     String              @db.LongText
  hashtags_template String?             @db.LongText
  is_default        Boolean             @default(false)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt
  localeRecord      Locale?             @relation(fields: [locale], references: [code], onDelete: SetNull)
  category          Category?           @relation(fields: [category_id], references: [id], onDelete: SetNull)
  streams           PublishingStream[]  @relation("StreamDefaultTemplate")

  @@unique([name, platform, locale])
  @@index([platform, locale, is_default])
  @@index([platform, category_id])
  @@map("destination_template")
}

model SEORecord {
  id                  String          @id @default(cuid())
  post_translation_id String          @unique
  canonical_url       String          @db.VarChar(2048)
  meta_title          String          @db.VarChar(255)
  meta_description    String          @db.LongText
  og_title            String          @db.VarChar(255)
  og_description      String          @db.LongText
  og_image_id         String?
  twitter_title       String          @db.VarChar(255)
  twitter_description String          @db.LongText
  keywords_json       Json
  authors_json        Json
  noindex             Boolean         @default(false)
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  postTranslation     PostTranslation @relation(fields: [post_translation_id], references: [id], onDelete: Cascade)
  ogImage             MediaAsset?     @relation("SeoOgImage", fields: [og_image_id], references: [id], onDelete: SetNull)

  @@map("seo_record")
}

model ViewEvent {
  id           String        @id @default(cuid())
  post_id      String?
  path         String        @db.VarChar(2048)
  locale       String        @db.VarChar(16)
  event_type   ViewEventType
  ip_hash      String        @db.VarChar(255)
  user_agent   String?       @db.VarChar(512)
  referrer     String?       @db.VarChar(2048)
  created_at   DateTime      @default(now())
  post         Post?         @relation(fields: [post_id], references: [id], onDelete: SetNull)
  localeRecord Locale        @relation(fields: [locale], references: [code], onDelete: Restrict)

  @@index([event_type, created_at])
  @@index([post_id, created_at])
  @@map("view_event")
}

model WebVitalMetric {
  id               String   @id @default(cuid())
  metric_id        String   @db.VarChar(128)
  name             String   @db.VarChar(16)
  rating           String   @db.VarChar(16)
  path             String   @db.VarChar(2048)
  route_group      String   @db.VarChar(64)
  locale           String?  @db.VarChar(16)
  label            String?  @db.VarChar(32)
  navigation_type  String?  @db.VarChar(32)
  form_factor      String   @db.VarChar(16)
  connection_type  String?  @db.VarChar(32)
  viewport_width   Int?
  viewport_height  Int?
  value            Float
  delta            Float?
  build_id         String?  @db.VarChar(128)
  attribution_json Json?
  created_at       DateTime @default(now())

  @@index([name, created_at])
  @@index([path(length: 191), name, created_at])
  @@index([route_group, name, created_at])
  @@index([form_factor, name, created_at])
  @@index([build_id, name, created_at])
  @@map("web_vital_metric")
}

model AuditEvent {
  id           String   @id @default(cuid())
  actor_id     String?
  entity_type  String   @db.VarChar(64)
  entity_id    String   @db.VarChar(191)
  action       String   @db.VarChar(64)
  payload_json Json?
  created_at   DateTime @default(now())
  actor        User?    @relation(fields: [actor_id], references: [id], onDelete: SetNull)

  @@map("audit_event")
}

model PostCategory {
  post_id     String
  category_id String
  post        Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([post_id, category_id])
  @@index([category_id])
  @@map("post_category")
}

model StreamCategory {
  stream_id   String
  category_id String
  stream      PublishingStream @relation(fields: [stream_id], references: [id], onDelete: Cascade)
  category    Category         @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([stream_id, category_id])
  @@index([category_id])
  @@map("stream_category")
}

model PublishAttempt {
  id                 String               @id @default(cuid())
  article_match_id   String
  stream_id          String
  destination_id     String
  post_id            String?
  platform           DestinationPlatform
  status             PublishAttemptStatus @default(PENDING)
  attempt_number     Int                  @default(1)
  retry_count        Int                  @default(0)
  idempotency_key    String               @unique @db.VarChar(191)
  payload_json       Json?
  response_json      Json?
  diagnostics_json   Json?
  remote_id          String?              @db.VarChar(191)
  last_error_code    String?              @db.VarChar(128)
  last_error_message String?              @db.LongText
  last_error_at      DateTime?
  retryable          Boolean              @default(false)
  available_at       DateTime             @default(now())
  lease_owner        String?              @db.VarChar(191)
  lease_expires_at   DateTime?
  heartbeat_at       DateTime?
  orphaned_at        DateTime?
  queued_at          DateTime             @default(now())
  started_at         DateTime?
  completed_at       DateTime?
  published_at       DateTime?
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt
  articleMatch       ArticleMatch         @relation(fields: [article_match_id], references: [id], onDelete: Cascade)
  stream             PublishingStream     @relation(fields: [stream_id], references: [id], onDelete: Cascade)
  destination        Destination          @relation(fields: [destination_id], references: [id], onDelete: Cascade)
  post               Post?                @relation(fields: [post_id], references: [id], onDelete: SetNull)

  @@index([destination_id, status, available_at])
  @@index([stream_id, status, available_at])
  @@index([status, lease_expires_at])
  @@index([post_id, platform, status])
  @@index([post_id, created_at])
  @@map("publish_attempt")
}

model FetchRun {
  id                          String             @id @default(cuid())
  stream_id                   String
  provider_config_id          String
  requested_by_id             String?
  trigger_type                String             @db.VarChar(32)
  status                      FetchRunStatus     @default(PENDING)
  queue_key                   String?            @unique @db.VarChar(191)
  available_at                DateTime           @default(now())
  lease_owner                 String?            @db.VarChar(191)
  lease_expires_at            DateTime?
  heartbeat_at                DateTime?
  attempt_count               Int                @default(0)
  last_error_code             String?            @db.VarChar(128)
  last_error_message          String?            @db.LongText
  last_error_at               DateTime?
  orphaned_at                 DateTime?
  window_start                DateTime?
  window_end                  DateTime?
  fetched_count               Int                @default(0)
  publishable_count           Int                @default(0)
  held_count                  Int                @default(0)
  duplicate_count             Int                @default(0)
  skipped_count               Int                @default(0)
  queued_count                Int                @default(0)
  optimized_count             Int                @default(0)
  blocked_count               Int                @default(0)
  ai_cache_hit_count          Int                @default(0)
  published_count             Int                @default(0)
  failed_count                Int                @default(0)
  provider_cursor_before_json Json?
  provider_cursor_after_json  Json?
  execution_details_json      Json?
  started_at                  DateTime?
  finished_at                 DateTime?
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  stream                      PublishingStream   @relation(fields: [stream_id], references: [id], onDelete: Cascade)
  providerConfig              NewsProviderConfig @relation(fields: [provider_config_id], references: [id], onDelete: Restrict)
  requestedBy                 User?              @relation("FetchRunRequester", fields: [requested_by_id], references: [id], onDelete: SetNull)

  @@index([stream_id, started_at])
  @@index([status, available_at])
  @@index([status, lease_expires_at])
  @@map("fetch_run")
}
