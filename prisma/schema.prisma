generator client {
  provider = "prisma-client-js"
  compilerBuild = "small"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum EditorialStage {
  INGESTED
  REVIEWED
  EDITED
  APPROVED
}

enum WorkflowStage {
  INGESTED
  OPTIMIZED
  HELD
  REVIEW_REQUIRED
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum OptimizationStatus {
  NOT_REQUESTED
  PENDING
  COMPLETED
  FALLBACK
  SKIPPED
  FAILED
}

enum PolicyReviewStatus {
  PASS
  HOLD
  BLOCK
}

enum DestinationPlatform {
  WEBSITE
  FACEBOOK
  INSTAGRAM
}

enum DestinationKind {
  WEBSITE
  FACEBOOK_PROFILE
  FACEBOOK_PAGE
  INSTAGRAM_PERSONAL
  INSTAGRAM_BUSINESS
}

enum ConnectionStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum StreamMode {
  AUTO_PUBLISH
  REVIEW_REQUIRED
}

enum StreamStatus {
  ACTIVE
  PAUSED
}

enum ArticleMatchStatus {
  ELIGIBLE
  HELD_FOR_REVIEW
  QUEUED
  PUBLISHED
  FAILED
  DUPLICATE
  SKIPPED
}

enum PublishAttemptStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum FetchRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ViewEventType {
  WEBSITE_VIEW
  PAGE_VIEW
  POST_VIEW
  SEARCH_VIEW
}

model Locale {
  code                 String                @id @db.VarChar(16)
  name                 String                @db.VarChar(64)
  isActive             Boolean               @default(true)
  isDefault            Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  postTranslations     PostTranslation[]
  destinationTemplates DestinationTemplate[]
  optimizationCaches   OptimizationCache[]
  publishingStreams    PublishingStream[]
  viewEvents           ViewEvent[]

  @@map("locale")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique @db.VarChar(191)
  name          String         @db.VarChar(191)
  passwordHash  String         @db.VarChar(255)
  role          UserRole
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  adminSessions AdminSession[]
  authoredPosts Post[]         @relation("PostAuthor")
  auditEvents   AuditEvent[]
  fetchRuns     FetchRun[]     @relation("FetchRunRequester")

  @@map("user")
}

model AdminSession {
  id            String   @id @default(cuid())
  userId        String
  tokenHash     String   @unique @db.VarChar(64)
  expiresAt     DateTime
  invalidatedAt DateTime?
  createdAt     DateTime @default(now())
  lastUsedAt    DateTime @default(now())
  userAgent     String?  @db.VarChar(512)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@map("adminsession")
}

model NewsProviderConfig {
  id                  String                   @id @default(cuid())
  providerKey         String                   @unique @db.VarChar(64)
  label               String                   @db.VarChar(191)
  description         String?                  @db.LongText
  baseUrl             String?                  @db.VarChar(2048)
  isDefault           Boolean                  @default(false)
  isEnabled           Boolean                  @default(true)
  isSelectable        Boolean                  @default(true)
  requestDefaultsJson Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  streams             PublishingStream[]       @relation("StreamProvider")
  checkpoints         ProviderFetchCheckpoint[]
  fetchedArticles     FetchedArticle[]
  fetchRuns           FetchRun[]

  @@index([isEnabled, isDefault])
  @@map("newsproviderconfig")
}

model Destination {
  id                       String           @id @default(cuid())
  name                     String           @db.VarChar(191)
  slug                     String           @unique @db.VarChar(191)
  platform                 DestinationPlatform
  kind                     DestinationKind
  accountHandle            String?          @db.VarChar(191)
  externalAccountId        String?          @db.VarChar(191)
  connectionStatus         ConnectionStatus @default(DISCONNECTED)
  connectionError          String?          @db.LongText
  encryptedTokenCiphertext String?          @db.LongText
  encryptedTokenIv         String?          @db.VarChar(64)
  encryptedTokenTag        String?          @db.VarChar(64)
  tokenHint                String?          @db.VarChar(64)
  settingsJson             Json?
  lastCheckedAt            DateTime?
  lastConnectedAt          DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  streams                  PublishingStream[]
  articleMatches           ArticleMatch[]
  publishAttempts          PublishAttempt[]

  @@index([platform, connectionStatus])
  @@map("destination")
}

model Category {
  id                   String                @id @default(cuid())
  name                 String                @unique @db.VarChar(191)
  slug                 String                @unique @db.VarChar(191)
  description          String?               @db.LongText
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  posts                PostCategory[]
  streamAssignments    StreamCategory[]
  destinationTemplates DestinationTemplate[]

  @@map("category")
}

model MediaAsset {
  id              String          @id @default(cuid())
  fileName        String?         @db.VarChar(255)
  fileSizeBytes   Int?
  storageDriver   String          @db.VarChar(32)
  storageKey      String?         @db.VarChar(255)
  publicUrl       String?         @db.VarChar(2048)
  localPath       String?         @db.VarChar(512)
  sourceUrl       String?         @db.VarChar(2048)
  sourceDomain    String?         @db.VarChar(191)
  alt             String?         @db.LongText
  caption         String?         @db.LongText
  mimeType        String?         @db.VarChar(191)
  width           Int?
  height          Int?
  attributionText String?         @db.LongText
  licenseType     String?         @db.VarChar(128)
  licenseNotes    String?         @db.LongText
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  variants        MediaVariant[]
  featuredInPosts Post[]          @relation("PostFeaturedImage")
  fetchedArticles FetchedArticle[]
  seoOgRecords    SEORecord[]     @relation("SeoOgImage")

  @@index([sourceDomain])
  @@map("mediaasset")
}

model MediaVariant {
  id            String     @id @default(cuid())
  mediaAssetId  String
  variantKey    String     @db.VarChar(64)
  format        String     @db.VarChar(32)
  mimeType      String?    @db.VarChar(191)
  width         Int
  height        Int
  fileSizeBytes Int?
  storageKey    String?    @db.VarChar(255)
  publicUrl     String?    @db.VarChar(2048)
  localPath     String?    @db.VarChar(512)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  mediaAsset    MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([mediaAssetId])
  @@index([mediaAssetId, variantKey])
  @@map("mediavariant")
}

model FetchedArticle {
  id                     String             @id @default(cuid())
  providerConfigId       String
  featuredMediaId        String?
  providerArticleId      String?            @db.VarChar(191)
  dedupeFingerprint      String             @unique @db.VarChar(191)
  sourceUrlHash          String?            @db.VarChar(64)
  normalizedTitleHash    String             @db.VarChar(64)
  sourceName             String             @db.VarChar(191)
  sourceUrl              String             @db.VarChar(2048)
  title                  String             @db.VarChar(255)
  summary                String?            @db.LongText
  body                   String?            @db.LongText
  author                 String?            @db.VarChar(191)
  publishedAt            DateTime
  imageUrl               String?            @db.VarChar(2048)
  language               String?            @db.VarChar(32)
  providerCategoriesJson Json?
  providerCountriesJson  Json?
  providerRegionsJson    Json?
  tagsJson               Json?
  rawPayloadJson         Json?
  fetchTimestamp         DateTime           @default(now())
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  providerConfig         NewsProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  featuredMedia          MediaAsset?        @relation(fields: [featuredMediaId], references: [id], onDelete: SetNull)
  articleMatches         ArticleMatch[]
  posts                  Post[]             @relation("PostSourceArticle")

  @@unique([providerConfigId, providerArticleId])
  @@index([providerConfigId, publishedAt])
  @@index([sourceUrlHash, publishedAt])
  @@index([normalizedTitleHash, publishedAt])
  @@map("fetchedarticle")
}

model Post {
  id                 String          @id @default(cuid())
  sourceArticleId    String?         @unique
  slug               String          @unique @db.VarChar(191)
  status             PostStatus      @default(DRAFT)
  editorialStage     EditorialStage  @default(INGESTED)
  canonicalContentHash String?       @db.VarChar(64)
  sourceName         String          @db.VarChar(191)
  sourceUrl          String          @db.VarChar(2048)
  providerKey        String          @db.VarChar(64)
  excerpt            String          @db.LongText
  featuredImageId    String?
  authorId           String?
  scheduledPublishAt DateTime?
  publishedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  sourceArticle      FetchedArticle? @relation("PostSourceArticle", fields: [sourceArticleId], references: [id], onDelete: SetNull)
  featuredImage      MediaAsset?     @relation("PostFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  author             User?           @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  translations       PostTranslation[]
  categories         PostCategory[]
  articleMatches     ArticleMatch[]
  publishAttempts    PublishAttempt[]
  viewEvents         ViewEvent[]

  @@index([status, publishedAt])
  @@index([status, scheduledPublishAt])
  @@map("post")
}

model PostTranslation {
  id                    String          @id @default(cuid())
  postId                String
  locale                String          @db.VarChar(16)
  title                 String          @db.VarChar(255)
  summary               String          @db.LongText
  contentMd             String          @db.LongText
  contentHtml           String          @db.LongText
  structuredContentJson Json
  sourceAttribution     String          @db.LongText
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  post                  Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  localeRecord          Locale          @relation(fields: [locale], references: [code], onDelete: Restrict)
  seoRecord             SEORecord?

  @@unique([postId, locale])
  @@index([locale, postId])
  @@map("posttranslation")
}

model ProviderFetchCheckpoint {
  id                    String             @id @default(cuid())
  streamId              String
  providerConfigId      String
  lastSuccessfulFetchAt DateTime?
  cursorJson            Json?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  stream                PublishingStream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  providerConfig        NewsProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@unique([streamId, providerConfigId])
  @@map("providerfetchcheckpoint")
}

model PublishingStream {
  id                      String               @id @default(cuid())
  name                    String               @db.VarChar(191)
  slug                    String               @unique @db.VarChar(191)
  description             String?              @db.LongText
  destinationId           String
  activeProviderId        String
  defaultTemplateId       String?
  locale                  String               @db.VarChar(16)
  timezone                String               @db.VarChar(64)
  scheduleIntervalMinutes Int                  @default(60)
  scheduleExpression      String?              @db.VarChar(128)
  mode                    StreamMode
  status                  StreamStatus         @default(ACTIVE)
  maxPostsPerRun          Int                  @default(5)
  duplicateWindowHours    Int                  @default(48)
  retryLimit              Int                  @default(3)
  retryBackoffMinutes     Int                  @default(15)
  languageAllowlistJson   Json?
  countryAllowlistJson    Json?
  regionAllowlistJson     Json?
  includeKeywordsJson     Json?
  excludeKeywordsJson     Json?
  settingsJson            Json?
  consecutiveFailureCount Int                  @default(0)
  lastRunStartedAt        DateTime?
  lastRunCompletedAt      DateTime?
  lastFailureAt           DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  destination             Destination          @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  activeProvider          NewsProviderConfig   @relation("StreamProvider", fields: [activeProviderId], references: [id], onDelete: Restrict)
  defaultTemplate         DestinationTemplate? @relation("StreamDefaultTemplate", fields: [defaultTemplateId], references: [id], onDelete: SetNull)
  localeRecord            Locale               @relation(fields: [locale], references: [code], onDelete: Restrict)
  categories              StreamCategory[]
  checkpoints             ProviderFetchCheckpoint[]
  articleMatches          ArticleMatch[]
  publishAttempts         PublishAttempt[]
  fetchRuns               FetchRun[]

  @@index([status, destinationId])
  @@index([destinationId, mode, status])
  @@index([activeProviderId, status])
  @@map("publishingstream")
}

model ArticleMatch {
  id                  String             @id @default(cuid())
  fetchedArticleId    String
  streamId            String
  destinationId       String
  canonicalPostId     String?
  optimizationCacheId String?
  status              ArticleMatchStatus
  workflowStage       WorkflowStage      @default(INGESTED)
  optimizationStatus  OptimizationStatus @default(NOT_REQUESTED)
  policyStatus        PolicyReviewStatus @default(PASS)
  optimizationHash    String?            @db.VarChar(64)
  optimizedPayloadJson Json?
  policyReasonsJson   Json?
  readinessChecksJson Json?
  banRiskScore        Int?
  lastOptimizedAt     DateTime?
  lastPolicyCheckedAt DateTime?
  reviewNotes         String?            @db.LongText
  filterReasonsJson   Json?
  holdReasonsJson     Json?
  duplicateOfMatchId  String?
  duplicateFingerprint String?          @db.VarChar(191)
  queuedAt            DateTime?
  publishedAt         DateTime?
  failedAt            DateTime?
  overrideNotes       String?            @db.LongText
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  fetchedArticle      FetchedArticle     @relation(fields: [fetchedArticleId], references: [id], onDelete: Cascade)
  stream              PublishingStream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  destination         Destination        @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  canonicalPost       Post?              @relation(fields: [canonicalPostId], references: [id], onDelete: SetNull)
  optimizationCache   OptimizationCache? @relation(fields: [optimizationCacheId], references: [id], onDelete: SetNull)
  duplicateOf         ArticleMatch?      @relation("DuplicateArticleMatch", fields: [duplicateOfMatchId], references: [id], onDelete: SetNull)
  duplicates          ArticleMatch[]     @relation("DuplicateArticleMatch")
  publishAttempts     PublishAttempt[]

  @@unique([fetchedArticleId, streamId])
  @@index([streamId, status])
  @@index([streamId, workflowStage])
  @@index([destinationId, status])
  @@index([destinationId, policyStatus])
  @@index([canonicalPostId])
  @@map("articlematch")
}

model OptimizationCache {
  id               String             @id @default(cuid())
  cacheKey         String             @unique @db.VarChar(191)
  contentHash      String             @db.VarChar(64)
  settingsHash     String             @db.VarChar(64)
  optimizationHash String             @db.VarChar(64)
  locale           String?            @db.VarChar(16)
  platform         DestinationPlatform
  destinationKind  DestinationKind
  status           OptimizationStatus @default(PENDING)
  policyStatus     PolicyReviewStatus @default(PASS)
  provider         String?            @db.VarChar(64)
  model            String?            @db.VarChar(128)
  usedFallback     Boolean            @default(false)
  banRiskScore     Int?
  resultJson       Json?
  warningsJson     Json?
  errorMessage     String?            @db.LongText
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  localeRecord     Locale?            @relation(fields: [locale], references: [code], onDelete: SetNull)
  articleMatches   ArticleMatch[]

  @@index([platform, destinationKind, locale])
  @@index([status, updatedAt])
  @@map("optimizationcache")
}

model DestinationTemplate {
  id               String              @id @default(cuid())
  name             String              @db.VarChar(191)
  platform         DestinationPlatform
  locale           String?             @db.VarChar(16)
  categoryId       String?
  titleTemplate    String?             @db.LongText
  summaryTemplate  String?             @db.LongText
  bodyTemplate     String              @db.LongText
  hashtagsTemplate String?             @db.LongText
  isDefault        Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  localeRecord     Locale?             @relation(fields: [locale], references: [code], onDelete: SetNull)
  category         Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  streams          PublishingStream[]  @relation("StreamDefaultTemplate")

  @@unique([name, platform, locale])
  @@index([platform, locale, isDefault])
  @@index([platform, categoryId])
  @@map("destinationtemplate")
}

model SEORecord {
  id                 String          @id @default(cuid())
  postTranslationId  String          @unique
  canonicalUrl       String          @db.VarChar(2048)
  metaTitle          String          @db.VarChar(255)
  metaDescription    String          @db.LongText
  ogTitle            String          @db.VarChar(255)
  ogDescription      String          @db.LongText
  ogImageId          String?
  twitterTitle       String          @db.VarChar(255)
  twitterDescription String          @db.LongText
  keywordsJson       Json
  authorsJson        Json
  noindex            Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  postTranslation    PostTranslation @relation(fields: [postTranslationId], references: [id], onDelete: Cascade)
  ogImage            MediaAsset?     @relation("SeoOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)

  @@map("seorecord")
}

model ViewEvent {
  id           String        @id @default(cuid())
  postId       String?
  path         String        @db.VarChar(2048)
  locale       String        @db.VarChar(16)
  eventType    ViewEventType
  ipHash       String        @db.VarChar(255)
  userAgent    String?       @db.VarChar(512)
  referrer     String?       @db.VarChar(2048)
  createdAt    DateTime      @default(now())
  post         Post?         @relation(fields: [postId], references: [id], onDelete: SetNull)
  localeRecord Locale        @relation(fields: [locale], references: [code], onDelete: Restrict)

  @@index([eventType, createdAt])
  @@index([postId, createdAt])
  @@map("viewevent")
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorId     String?
  entityType  String   @db.VarChar(64)
  entityId    String   @db.VarChar(191)
  action      String   @db.VarChar(64)
  payloadJson Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@map("auditevent")
}

model PostCategory {
  postId     String
  categoryId String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([categoryId])
  @@map("postcategory")
}

model StreamCategory {
  streamId   String
  categoryId String
  stream     PublishingStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  category   Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([streamId, categoryId])
  @@index([categoryId])
  @@map("streamcategory")
}

model PublishAttempt {
  id             String               @id @default(cuid())
  articleMatchId String
  streamId       String
  destinationId  String
  postId         String?
  platform       DestinationPlatform
  status         PublishAttemptStatus @default(PENDING)
  attemptNumber  Int                  @default(1)
  retryCount     Int                  @default(0)
  idempotencyKey String               @unique @db.VarChar(191)
  payloadJson    Json?
  responseJson   Json?
  diagnosticsJson Json?
  remoteId       String?              @db.VarChar(191)
  errorCode      String?              @db.VarChar(128)
  errorMessage   String?              @db.LongText
  retryable      Boolean              @default(false)
  queuedAt       DateTime             @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  publishedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  articleMatch   ArticleMatch         @relation(fields: [articleMatchId], references: [id], onDelete: Cascade)
  stream         PublishingStream     @relation(fields: [streamId], references: [id], onDelete: Cascade)
  destination    Destination          @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  post           Post?                @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([destinationId, status, createdAt])
  @@index([streamId, status, createdAt])
  @@index([postId, createdAt])
  @@map("publishattempt")
}

model FetchRun {
  id                      String             @id @default(cuid())
  streamId                String
  providerConfigId        String
  requestedById           String?
  triggerType             String             @db.VarChar(32)
  status                  FetchRunStatus     @default(PENDING)
  windowStart             DateTime?
  windowEnd               DateTime?
  fetchedCount            Int                @default(0)
  publishableCount        Int                @default(0)
  heldCount               Int                @default(0)
  duplicateCount          Int                @default(0)
  skippedCount            Int                @default(0)
  queuedCount             Int                @default(0)
  optimizedCount          Int                @default(0)
  blockedCount            Int                @default(0)
  aiCacheHitCount         Int                @default(0)
  publishedCount          Int                @default(0)
  failedCount             Int                @default(0)
  errorMessage            String?            @db.LongText
  providerCursorBeforeJson Json?
  providerCursorAfterJson  Json?
  executionDetailsJson    Json?
  startedAt               DateTime           @default(now())
  finishedAt              DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  stream                  PublishingStream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  providerConfig          NewsProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  requestedBy             User?              @relation("FetchRunRequester", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([streamId, startedAt])
  @@index([status, startedAt])
  @@map("fetchrun")
}
