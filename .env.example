# Copy this file to `.env.development` for local development or `.env.production`
# for cPanel deployments that cannot use the environment variable panel.
# Do not create `.env*.local` files in this repository or in release bundles.
# Runtime precedence is: existing process environment, then the mode-specific
# env file, then `.env`. Rotate any credentials that were previously shared.
DATABASE_URL="mysql://news_pub:replace-with-local-db-password@localhost:3306/news_pub"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_IMAGE_REMOTE_HOSTS="cdn.example.com"
DEFAULT_LOCALE="en"
SUPPORTED_LOCALES="en"

SESSION_SECRET="replace-with-a-long-random-local-session-secret"
SESSION_MAX_AGE_SECONDS="28800"
ADMIN_SEED_EMAIL="replace-me-local-admin@example.test"
ADMIN_SEED_PASSWORD="replace-with-a-unique-local-admin-password"
# Optional: lower only for very constrained environments such as small cPanel plans.
# ADMIN_PASSWORD_HASH_COST="16384"
# ADMIN_PASSWORD_HASH_MAX_MEMORY_BYTES="134217728"
# By default cpanel:db:deploy applies migrations only. Set this only when you intentionally
# want one-step migration plus seed after upload. SKIP_DB_SEED_ON_DEPLOY always wins.
# RUN_DB_SEED_ON_DEPLOY="0"
# SKIP_DB_SEED_ON_DEPLOY="1"

MEDIASTACK_API_KEY=""
NEWSDATA_API_KEY=""
NEWSAPI_API_KEY=""
DESTINATION_TOKEN_ENCRYPTION_KEY="replace-with-a-long-random-local-encryption-key"
# Meta setup
# Preferred for automated Facebook Page publishing: a system-user access token.
META_SYSTEM_USER_ACCESS_TOKEN=""
# Optional app credentials used for Meta integrations and lifecycle management.
META_APP_ID="replace-with-meta-app-id-if-used-locally"
META_APP_SECRET=""
# Long-lived User access token used to discover connected Pages/Instagram accounts and derive fresh Page credentials at runtime.
# NewsPub stores the selected page/account identity and resolves a fresh valid publish credential at runtime when possible.
META_USER_ACCESS_TOKEN=""
# Optional: override the default Graph API version/base URL.
# META_GRAPH_API_BASE_URL="https://graph.facebook.com/v25.0"
# Optional: global guardrail defaults. Leave unset to use built-in defaults or per-destination overrides.
# META_SOCIAL_MIN_POST_INTERVAL_MINUTES="90"
# META_SOCIAL_DUPLICATE_COOLDOWN_HOURS="72"
# META_FACEBOOK_MAX_POSTS_PER_24H="12"
# META_INSTAGRAM_MAX_POSTS_PER_24H="20"
# META_INSTAGRAM_MAX_HASHTAGS="8"

# AI-assisted optimization
# NewsPub uses AI only for bounded, auditable rewriting, SEO packaging, and
# destination-specific formatting. If OPENAI_API_KEY is absent, the app falls
# back to deterministic formatting without inventing facts.
OPENAI_API_KEY=""
AI_MODEL="gpt-4.1-mini"
AI_OPTIMIZATION_ENABLED="true"
AI_MAX_SOURCE_CHARS="6000"
AI_REQUEST_TIMEOUT_MS="20000"
PLATFORM_POLICY_BLOCKLIST="act now,click here,guaranteed,hate,violent threat,you won't believe"
PLATFORM_POLICY_HOLD_SCORE="45"
PLATFORM_POLICY_BLOCK_SCORE="70"

MEDIA_DRIVER="local"
LOCAL_MEDIA_BASE_PATH="public/uploads"
LOCAL_MEDIA_BASE_URL="/uploads"
S3_MEDIA_BUCKET="your-bucket"
S3_MEDIA_REGION="your-region"
S3_MEDIA_BASE_URL="https://cdn.example.com"
S3_ACCESS_KEY_ID="replace-with-local-s3-access-key"
S3_SECRET_ACCESS_KEY="replace-with-local-s3-secret-key"
UPLOAD_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp"
MEDIA_MAX_REMOTE_FILE_BYTES="5242880"
SHARP_CONCURRENCY="1"
OUTBOUND_FETCH_TIMEOUT_MS="10000"
OUTBOUND_FETCH_RETRY_COUNT="2"

REVALIDATE_SECRET="replace-with-a-long-random-local-revalidate-secret"
CRON_SECRET="replace-with-a-long-random-local-cron-secret"
ENABLE_ANALYTICS="true"
ENABLE_METRICS="true"
DEFAULT_SCHEDULE_TIMEZONE="UTC"
INITIAL_BACKFILL_HOURS="24"
