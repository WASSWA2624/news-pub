{
  "watch": [
    ".env.development.local",
    ".env",
    "jsconfig.json",
    "next.config.mjs",
    "package.json",
    "prisma/schema.prisma"
  ],
  "ignore": [
    ".next",
    "coverage",
    "dev-plan",
    "docs",
    "node_modules"
  ],
  "ext": "js,json,mjs,prisma",
  "delay": "300",
  "exec": "node scripts/dev-next.js"
}
