{
  "name": "news-pub",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "db:bootstrap": "node scripts/bootstrap-dev-db.js",
    "db:reset": "node scripts/reset-db.js",
    "dev": "npm run db:bootstrap && nodemon --config nodemon.json",
    "dev:next": "node scripts/dev-next.js",
    "prebuild": "node scripts/prepare-next-build.js && prisma generate",
    "prestart": "npm run build",
    "build": "next build",
    "build:cpanel": "npm run build && node scripts/build-cpanel-package.js",
    "cpanel:db:seed": "node scripts/cpanel-db-seed.js",
    "start": "node scripts/start-standalone.js",
    "lint": "eslint .",
    "repo:check": "node scripts/check-repo-hygiene.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:seed": "prisma generate && prisma db seed"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.51",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@reduxjs/toolkit": "^2.11.2",
    "ai": "^6.0.149",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "^9.2.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "styled-components": "^6.3.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "nodemon": "^3.1.14",
    "prisma": "^7.6.0",
    "vitest": "^4.1.2"
  }
}
